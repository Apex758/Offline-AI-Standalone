{
  "name": "oecs-teacher-assistant",
  "version": "2.0.0",
  "description": "OECS Teacher Assistant - AI-powered educational tools suite by the Organisation of Eastern Caribbean States",
  "main": "electron/main.js",
  "author": {
    "name": "Delon Pierre",
    "email": "delon.pierre@oecs.int"
  },
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "cd frontend && npm run dev",
    "backend": "cd backend && venv\\Scripts\\python.exe -m uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "electron:dev": "concurrently \"npm run backend\" \"wait-on http-get://localhost:8000/api/health && npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "echo Backend packaging skipped - already done manually",
    "build": "npm run build:frontend && npm run build:backend",
    "electron:build": "npm run build && electron-builder",
    "electron:build:win": "npm run build && electron-builder --win --x64",
    "electron:build:portable": "npm run build && electron-builder --win portable",
    "package": "npm run build && electron-builder --win --x64",
    "postinstall": "cd frontend && npm install"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "electron-log": "^5.0.1",
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "app-builder-bin": "^4.2.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "40.8.5",
    "electron-builder": "^26.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.oecs.teacherassistant",
    "productName": "OECS Teacher Assistant",
    "copyright": "Copyright 2026 Organisation of Eastern Caribbean States. Developed by Delon Pierre.",
    "files": [
      "frontend/dist/**/*",
      "electron/**/*",
      "package.json",
      "!**/*.md",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend-bundle",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/venv/**",
          "!**/.venv/**",
          "!chat_history.json",
          "!lesson_plan_history.json",
          "!data/**",
          "!bin/Release/test-*.exe",
          "!bin/Release/llama-batched.exe",
          "!bin/Release/llama-batched-bench.exe",
          "!bin/Release/llama-bench.exe",
          "!bin/Release/llama-convert-llama2c-to-ggml.exe",
          "!bin/Release/llama-cvector-generator.exe",
          "!bin/Release/llama-diffusion-cli.exe",
          "!bin/Release/llama-embedding.exe",
          "!bin/Release/llama-eval-callback.exe",
          "!bin/Release/llama-export-lora.exe",
          "!bin/Release/llama-finetune.exe",
          "!bin/Release/llama-gemma3-cli.exe",
          "!bin/Release/llama-gen-docs.exe",
          "!bin/Release/llama-gguf.exe",
          "!bin/Release/llama-gguf-hash.exe",
          "!bin/Release/llama-gguf-split.exe",
          "!bin/Release/llama-imatrix.exe",
          "!bin/Release/llama-llava-cli.exe",
          "!bin/Release/llama-logits.exe",
          "!bin/Release/llama-lookahead.exe",
          "!bin/Release/llama-lookup.exe",
          "!bin/Release/llama-lookup-create.exe",
          "!bin/Release/llama-lookup-merge.exe",
          "!bin/Release/llama-lookup-stats.exe",
          "!bin/Release/llama-minicpmv-cli.exe",
          "!bin/Release/llama-mtmd-cli.exe",
          "!bin/Release/llama-parallel.exe",
          "!bin/Release/llama-passkey.exe",
          "!bin/Release/llama-perplexity.exe",
          "!bin/Release/llama-q8dot.exe",
          "!bin/Release/llama-quantize.exe",
          "!bin/Release/llama-qwen2vl-cli.exe",
          "!bin/Release/llama-retrieval.exe",
          "!bin/Release/llama-run.exe",
          "!bin/Release/llama-save-load-state.exe",
          "!bin/Release/llama-server.exe",
          "!bin/Release/llama-simple.exe",
          "!bin/Release/llama-simple-chat.exe",
          "!bin/Release/llama-speculative.exe",
          "!bin/Release/llama-speculative-simple.exe",
          "!bin/Release/llama-tokenize.exe",
          "!bin/Release/llama-tts.exe",
          "!bin/Release/llama-vdot.exe",
          "!python-embed/Scripts/**",
          "!python-embed/Lib/site-packages/cmake/**",
          "!python-embed/Lib/site-packages/setuptools/**",
          "!python-embed/Lib/site-packages/pip/**",
          "!python-embed/Lib/site-packages/torch/bin/protoc.exe"
        ]
      },
      {
        "from": "frontend/dist/splashscreen",
        "to": "splashscreen",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/OECS.ico",
        "to": "tray-icon.ico"
      },
      {
        "from": "frontend/src/data",
        "to": "frontend/src/data",
        "filter": [
          "**/*.json"
        ]
      },
      {
        "from": "models/tts_voices",
        "to": "models/tts_voices",
        "filter": [
          "en_US-lessac-high.onnx",
          "en_US-lessac-high.onnx.json",
          "en_US-ryan-high.onnx",
          "en_US-ryan-high.onnx.json",
          "en_US-amy-medium.onnx",
          "en_US-amy-medium.onnx.json"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "**/*.pyd"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "include": "build/installer.nsh"
    },
    "directories": {
      "output": "dist-electron"
    },
    "publish": {
      "provider": "github",
      "owner": "Apex758",
      "repo": "OLH-Offline-Version-Updates",
      "private": true
    },
    "win": {
      "icon": "build/OECS.ico",
      "target": [
        "nsis"
      ]
    }
  }
}
